# ═══════════════════════════════════════════════════════════════
# ProposalAI — Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` on your DigitalOcean Droplet
# and fill in the values before running docker compose.

# ═══ Core ═══
NODE_ENV=production
PORT=8080

# ═══ PostgreSQL ═══
POSTGRES_USER=proposalai_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=proposalai
# DATABASE_URL is built inside docker-compose.prod.yml from these vars.

# ═══ Redis ═══
# Container-internal Redis is used automatically (redis://redis:6379)

# ═══ JWT — GENERATE STRONG SECRETS! ═══
# Run: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_RUN_OPENSSL_RAND
JWT_REFRESH_SECRET=CHANGE_ME_RUN_OPENSSL_RAND
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ═══ CORS ═══
CORS_ORIGIN=https://advisor.mestresdaweb.com.br,https://hub.mestresdaweb.com.br,https://dev.mestresdaweb.com.br

# ═══ Frontend URL (for email links, redirects, etc.) ═══
FRONTEND_URL=https://advisor.mestresdaweb.com.br

# ═══ Rate Limiting ═══
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ═══ Brevo (Transactional Email) ═══
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@mestresdaweb.com.br
BREVO_FROM_NAME=Mestres da Web

# ═══ WhatsApp Business (Meta Cloud API) ═══
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# ═══ Synthflow AI ═══
SYNTHFLOW_API_KEY=
SYNTHFLOW_MODEL_ID=

# ═══ Google Calendar Integration ═══
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://advisor.mestresdaweb.com.br/api/integrations/google/callback

# ═══ Google OAuth (Sign in with Google) ═══
GOOGLE_AUTH_CLIENT_ID=

# ═══ AI Services ═══
ANTHROPIC_API_KEY=

# ═══ SDR Automático ═══
SDR_CRON_INTERVAL=*/5 * * * *
SDR_BUSINESS_HOURS_START=08:00
SDR_BUSINESS_HOURS_END=18:00
SDR_TIMEZONE=America/Sao_Paulo
SDR_MAX_CALLS_PER_DAY=50

# ═══ Sentry (Error Tracking) ═══
# SENTRY_DSN=

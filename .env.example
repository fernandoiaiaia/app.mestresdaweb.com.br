# ═══════════════════════════════════════
# ProposalAI — Monorepo Environment Variables
# ═══════════════════════════════════════

# This file lists all necessary variables to run the services.
# When deploying to DigitalOcean App Platform, add these keys in the Environment Variables tab.

# ═══ Backend / API ═══
NODE_ENV=production
# In DO App Platform, HTTP PORT is dynamically assigned and injected, but you can set a default.
PORT=8080

# Database (PostgreSQL) - Use your DigitalOcean Managed Database connection string here
DATABASE_URL=postgresql://user:password@hostname:port/db_name?schema=public&sslmode=require

# Redis - Use your DigitalOcean Managed Redis connection string here
REDIS_URL=redis://hostname:port

# JWT Secrets - Generate strong random strings for these in production!
JWT_ACCESS_SECRET=your-secure-access-secret
JWT_REFRESH_SECRET=your-secure-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Add your production frontend URLs here
CORS_ORIGIN=https://your-comercial-app.app.digitalocean.com,https://your-cliente-app.app.digitalocean.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# DO Spaces (for uploads)
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_REGION=nyc3
# SPACES_BUCKET=proposalai-uploads
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ═══ Frontend Apps ═══
# Note: In DigitalOcean, standard Next.js environment variables (like NEXT_PUBLIC_API_URL) 
# must be configured in each Frontend component's Environmental Variables section.
# NEXT_PUBLIC_API_URL=https://your-api.app.digitalocean.com

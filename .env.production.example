NODE_ENV=production
PORT=8080

# ═══ Database ═══
DATABASE_URL=postgresql://<user>:<pass>@<do-managed-db-host>:25060/<db>?schema=public&sslmode=require
POSTGRES_USER=<user>
POSTGRES_PASSWORD=<pass>
POSTGRES_DB=proposalai

# ═══ Redis ═══
REDIS_URL=redis://redis:6379

# ═══ JWT (GERAR SECRETS FORTES!) ═══
JWT_ACCESS_SECRET=<gerar: openssl rand -hex 64>
JWT_REFRESH_SECRET=<gerar: openssl rand -hex 64>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ═══ CORS ═══
CORS_ORIGIN=https://advisor.mestresdaweb.com.br,https://dev.mestresdaweb.com.br,https://hub.mestresdaweb.com.br

# ═══ Frontend ═══
FRONTEND_URL=https://advisor.mestresdaweb.com.br

# ═══ Rate Limit (Produção) ═══
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ═══ Integrações ═══
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=
GOOGLE_AUTH_CLIENT_ID=
ANTHROPIC_API_KEY=

# ═══ WhatsApp Business API ═══
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ═══ SDR Settings ═══
SDR_CRON_INTERVAL=*/5 * * * *
SDR_BUSINESS_HOURS_START=08:00
SDR_BUSINESS_HOURS_END=18:00
SDR_TIMEZONE=America/Sao_Paulo
SDR_MAX_CALLS_PER_DAY=50

{
  "expo": {
    "name": "MDW Cliente",
    "slug": "mdw-cliente",
    "version": "1.0.0",
    "scheme": "mdw-cliente",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-ciano.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.mestresdaweb.cliente",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Permitir o uso de Face ID para um login rápido e seguro no acesso aos seus projetos e painel."
      }
    },
    "android": {
      "package": "br.com.mestresdaweb.cliente",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}

# ═══════════════════════════════════════
# ProposalAI — Backend Environment Variables
# ═══════════════════════════════════════

# Server
NODE_ENV=development
PORT=7777

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/proposalai_dev?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_ACCESS_SECRET=super-secret-access-key-change-in-prod
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:1100

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Sentry (optional)
# SENTRY_DSN=

# DO Spaces (optional, for uploads)
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_REGION=nyc3
# SPACES_BUCKET=proposalai-uploads
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_CDN_URL=

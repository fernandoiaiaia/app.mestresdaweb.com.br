// ═══════════════════════════════════════
// DEV PROJECTS (Web Dev Platform)
// ═══════════════════════════════════════

enum DevProjectPhase {
  requirements
  discovery
  development
  testing
  documentation
  delivery
}

enum DevProjectHealth {
  on_track
  at_risk
  delayed
}

enum DevTaskStatus {
  todo
  in_progress
  review
  done
}

enum DevTaskPriority {
  low
  medium
  high
  critical
}

model DevProject {
  id       String           @id @default(uuid())
  name     String
  client   String
  phase    DevProjectPhase  @default(requirements)
  health   DevProjectHealth @default(on_track)
  progress Int              @default(0)
  archived Boolean          @default(false)

  proposalId String? @unique @map("proposal_id")
  proposal   Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  assembledProposalId String? @unique @map("assembled_proposal_id")
  assembledProposal   AssembledProposal? @relation(fields: [assembledProposalId], references: [id], onDelete: SetNull)

  startDate DateTime? @map("start_date")
  deadline  DateTime?

  hoursEstimated Int @default(0) @map("hours_estimated")
  hoursUsed      Int @default(0) @map("hours_used")

  // Creator
  createdById String @map("created_by_id")
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks       DevTask[]
  members     DevProjectMember[]
  contacts    DevProjectContact[]
  signatories DevProjectSignatory[]
  documents   DevProjectDocument[]
  sprints     DevSprint[]

  @@index([createdById])
  @@map("dev_projects")
}

model DevTask {
  id          String          @id @default(uuid())
  title       String
  description String?         @db.Text
  status      DevTaskStatus   @default(todo)
  priority    DevTaskPriority @default(medium)
  epic        String?
  story       String?         @db.Text
  tags        String[]        @default([])
  blocked     Boolean         @default(false)

  estimatedHours Float     @default(0) @map("estimated_hours")
  loggedHours    Float     @default(0) @map("logged_hours")
  deadline       DateTime?

  projectId String     @map("project_id")
  project   DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  sprintId String?    @map("sprint_id")
  sprint   DevSprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  comments    DevTaskComment[]
  timeLogs    DevTaskTimeLog[]
  bugs        DevTaskBug[]
  attachments DevTaskAttachment[]
  history     DevTaskHistory[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([sprintId])
  @@index([status])
  @@map("dev_tasks")
}

// ── DevTask relations to comments and time logs are on the nested models ──

// ═══ DEV PROJECT — TEAM MEMBERS ═══

model DevProjectMember {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  userId    String @map("user_id")
  role      String @default("DEV") // DEV, TECH_LEAD, QA, DESIGNER, PO, GESTOR

  createdAt DateTime @default(now()) @map("created_at")

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User       @relation("DevProjectMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("dev_project_members")
}

// ═══ DEV PROJECT — CLIENT CONTACTS ═══

model DevProjectContact {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  name      String
  email     String?
  phone     String?

  createdAt DateTime @default(now()) @map("created_at")

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("dev_project_contacts")
}

// ═══ DEV PROJECT — SIGNATORIES ═══

model DevProjectSignatory {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  role      String // contratada, contratante, testemunha_1, testemunha_2
  source    String // team, client
  sourceId  String @map("source_id") // userId or contactId
  name      String

  createdAt DateTime @default(now()) @map("created_at")

  project       DevProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  docSignatures DevDocSignature[]

  @@unique([projectId, role])
  @@index([projectId])
  @@map("dev_project_signatories")
}

// ═══ DEV PROJECT — DOCUMENTS ═══

model DevProjectDocument {
  id           String  @id @default(uuid())
  projectId    String  @map("project_id")
  docType      String  @map("doc_type") // brd, contrato, frd, sad, brand-guide, design-system, story-map, sprint-review, roadmap, closure
  title        String
  fileName     String  @map("file_name")
  storedName   String  @map("stored_name")
  fileSize     Int     @map("file_size")
  mimeType     String  @default("application/pdf") @map("mime_type")
  status       String  @default("draft") // draft, sent, signed
  notes        String? @db.Text
  uploadedById String  @map("uploaded_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project    DevProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation("DocUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  signatures DevDocSignature[]

  @@index([projectId, docType])
  @@map("dev_project_documents")
}

// ═══ DEV DOCUMENT — SIGNATURES ═══

model DevDocSignature {
  id          String    @id @default(uuid())
  documentId  String    @map("document_id")
  signatoryId String?   @map("signatory_id")
  name        String
  email       String
  role        String // contratada, contratante, testemunha_1, testemunha_2
  status      String    @default("pending") // pending, code_sent, signed
  code        String?
  signedAt    DateTime? @map("signed_at")

  createdAt DateTime @default(now()) @map("created_at")

  document  DevProjectDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatory DevProjectSignatory? @relation(fields: [signatoryId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@map("dev_doc_signatures")
}

// ═══ DEV PROJECT — SPRINTS ═══

model DevSprint {
  id        String    @id @default(uuid())
  projectId String    @map("project_id")
  name      String
  goal      String?   @db.Text
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  status    String    @default("planned") // planned, active, completed
  sortOrder Int       @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   DevTask[]

  @@index([projectId])
  @@map("dev_sprints")
}

// ═══ DEV TASK — COMMENTS ═══

model DevTaskComment {
  id     String @id @default(uuid())
  taskId String @map("task_id")
  userId String @map("user_id")
  text   String @db.Text
  isRead Boolean @default(false) @map("is_read")


  createdAt DateTime @default(now()) @map("created_at")

  task DevTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User    @relation("TaskComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("dev_task_comments")
}

// ═══ DEV TASK — TIME LOGS ═══

model DevTaskTimeLog {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  hours       Float
  description String?  @db.Text
  date        DateTime @default(now())

  createdAt DateTime @default(now()) @map("created_at")

  task DevTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User    @relation("TaskTimeLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("dev_task_time_logs")
}

// ═══ DEV TASK — BUGS ═══

model DevTaskBug {
  id            String   @id @default(uuid())
  taskId        String   @map("task_id")
  description   String   @db.Text
  category      String   @default("functional")
  priority      String   @default("high")
  status        String   @default("open") // open, fixing, fixed
  reporterId    String   @map("reporter_id")
  assigneeId    String?  @map("assignee_id")
  hoursWorked   Float    @default(0) @map("hours_worked")
  attachmentIds String[] @default([]) @map("attachment_ids")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task     DevTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reporter User    @relation("TaskBugsReported", fields: [reporterId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskBugsAssigned", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@map("dev_task_bugs")
}

// ═══ DEV TASK — ATTACHMENTS ═══

model DevTaskAttachment {
  id           String @id @default(uuid())
  taskId       String @map("task_id")
  userId       String @map("user_id")
  originalName String @map("original_name")
  storedName   String @map("stored_name")
  mimeType     String @map("mime_type")
  size         Int

  createdAt DateTime @default(now()) @map("created_at")

  task DevTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User    @relation("TaskAttachments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("dev_task_attachments")
}

// ═══ DEV TASK — HISTORY (Activity Log) ═══

model DevTaskHistory {
  id          String @id @default(uuid())
  taskId      String @map("task_id")
  userId      String @map("user_id")
  action      String // status_change, comment, bug_report, bug_fixed, time_log, attachment_upload, attachment_delete, assignment, priority_change, description_update, task_created
  description String @db.Text
  metadata    Json?  @db.JsonB // extra data (e.g. old/new status, hours, etc.)

  createdAt DateTime @default(now()) @map("created_at")

  task DevTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User    @relation("TaskHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("dev_task_history")
}

// ═══ DEV PROJECT — SETTINGS ═══

model DevProjectSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  phases  Json @default("[]") @db.JsonB // [{name, checklist: string[]}]
  roles   Json @default("[]") @db.JsonB // [{name, permissions: string[]}]
  aiRules Json @default("[]") @map("ai_rules") @db.JsonB // [{description, threshold, unit, enabled}]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dev_project_settings")
}

// ═══════════════════════════════════════
// FEATURE LIBRARY
// ═══════════════════════════════════════

model FeatureCategory {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  name        String
  slug        String
  description String? @db.Text
  segment     String?
  status      String  @default("active") // active, draft, archived
  orderIndex  Int     @default(0) @map("order_index")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  modules FeatureModule[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("feature_categories")
}

model FeatureModule {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  name        String
  slug        String
  description String?  @db.Text
  objective   String?  @db.Text
  status      String   @default("active")
  platforms   String[] @default(["Web"])
  orderIndex  Int      @default(0) @map("order_index")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category FeatureCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  screens  FeatureScreen[]

  @@index([categoryId])
  @@map("feature_modules")
}

model FeatureScreen {
  id             String   @id @default(uuid())
  moduleId       String   @map("module_id")
  name           String
  slug           String
  description    String?  @db.Text
  objective      String?  @db.Text
  screenType     String   @default("Listagem") @map("screen_type")
  complexityBase String   @default("Média") @map("complexity_base")
  status         String   @default("active")
  platforms      String[] @default(["Web"])
  orderIndex     Int      @default(0) @map("order_index")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module   FeatureModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  features FeatureItem[]

  @@index([moduleId])
  @@map("feature_screens")
}

model FeatureItem {
  id                    String   @id @default(uuid())
  screenId              String   @map("screen_id")
  name                  String
  slug                  String
  descriptionFunc       String?  @map("description_func") @db.Text
  useCase               String?  @map("use_case") @db.Text
  businessIntent        String?  @map("business_intent") @db.Text
  contextTriggers       String[] @default([]) @map("context_triggers")
  interfaceExample      String?  @map("interface_example") @db.Text
  techType              String?  @map("tech_type")
  featurePattern        String?  @map("feature_pattern")
  complexity            String   @default("Média")
  algorithmicComplexity String   @default("baixa") @map("algorithmic_complexity")
  usageFrequency        String   @default("Comum") @map("usage_frequency")
  status                String   @default("active")
  platforms             String[] @default(["Web"])
  reusable              Boolean  @default(false)
  baseWeight            Float    @default(1) @map("base_weight")
  tags                  String[] @default([])
  observations          String?  @db.Text
  dependencies          String[] @default([])
  dependsOn             String[] @default([]) @map("depends_on")
  technicalComponents   String[] @default([]) @map("technical_components")
  externalIntegrations  String[] @default([]) @map("external_integrations")
  applicableSegments    String[] @default([]) @map("applicable_segments")
  rates                 Json     @default("{}") @db.JsonB
  orderIndex            Int      @default(0) @map("order_index")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  screen FeatureScreen @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@index([screenId])
  @@map("feature_items")
}

// ═══════════════════════════════════════
// LEADS (Inbound from contato.html)
// ═══════════════════════════════════════

model Lead {
  id     String  @id @default(uuid())
  userId String? @map("user_id") // Responsável atribuído (nullable: leads chegam sem dono)

  // Dados do formulário
  name     String
  email    String
  phone    String
  company  String?
  services String[] @default([]) // IDs dos serviços selecionados
  budget   Json?    @db.JsonB // { serviceId: { status, range } }
  message  String?  @db.Text

  // Gestão
  status String  @default("new") // "new", "contacted", "qualified", "converted", "lost"
  source String  @default("website") // "website", "referral", "ads", etc.
  notes  String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation("LeadOwner", fields: [userId], references: [id], onDelete: SetNull)
  whatsappContact WhatsappContact?

  @@index([userId])
  @@index([email])
  @@index([status])
  @@map("leads")
}

// ═══════════════════════════════════════
// PROPOSALS (Módulo de Propostas Comerciais)
// ═══════════════════════════════════════

model Proposal {
  id       String @id @default(uuid())
  userId   String @map("user_id")

  title     String
  clientId  String?   @map("client_id")
  expiresAt DateTime? @map("expires_at")
  scopeRaw  String    @db.Text  @map("scope_raw")
  status    String    @default("draft") // "draft", "sent", "accepted", "rejected"

  // Resultado da análise de gaps (armazenado como JSON)
  gapAnalysis Json?   @db.JsonB @map("gap_analysis")

  // Estimativa de esforço (armazenado como JSON)
  estimate    Json?   @db.JsonB @map("estimate")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  viewerId String? @map("viewer_id")
  viewer   User?   @relation("ProposalViewer", fields: [viewerId], references: [id], onDelete: SetNull)
  
  comments ProposalComment[]
  devProject DevProject?

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@map("proposals")
}

model ProposalComment {
  id         String   @id @default(uuid())
  proposalId String   @map("proposal_id")
  screenId   String   @map("screen_id")
  
  author     String
  content    String   @db.Text
  
  fileUrl    String?  @map("file_url")
  fileName   String?  @map("file_name")
  fileType   String?  @map("file_type")
  fileSize   Int?     @map("file_size")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([screenId])
  @@map("proposal_comments")
}

// ═══════════════════════════════════════
// ASSEMBLED PROPOSALS (Proposal AI)
// ═══════════════════════════════════════

model AssembledProposal {
  id              String   @id @default(uuid())
  userId          String   @map("user_id") // Account Owner
  
  title           String   @default("Nova Proposta")
  clientId        String?  @map("client_id")
  validityDays    Int      @default(15) @map("validity_days")
  dealId          String?  @map("deal_id")
  publicId        String?  @unique @map("public_id")
  viewerId        String?  @map("viewer_id")
  
  totalHours      Int      @default(0) @map("total_hours")
  scopeData       Json     @default("{}") @map("scope_data")
  
  // ═══ FILA E AUDITORIA (Queue) ═══
  status          String   @default("draft") // draft, in_review, needs_adjustment, approved, rejected
  urgency         String   @default("media")
  reviewHistory   Json     @default("[]") @map("review_history")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation("ProposalAccountOwner", fields: [userId], references: [id], onDelete: Cascade)
  viewer          User?    @relation("AssembledProposalViewer", fields: [viewerId], references: [id], onDelete: SetNull)
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  devProject      DevProject?

  @@index([userId])
  @@index([viewerId])
  @@index([clientId])
  @@index([dealId])
  @@map("assembled_proposals")
}

// ═══════════════════════════════════════
// KNOWLEDGE BASE (Proposal AI Context)
// ═══════════════════════════════════════

model KnowledgeBaseFile {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  name      String
  content   String @db.Text
  sizeBytes Int    @default(0) @map("size_bytes")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("knowledge_base_files")
}

// ═══════════════════════════════════════
// WHATSAPP - META CLOUD API MODULE
// ═══════════════════════════════════════

model WhatsappContact {
  id        String   @id @default(uuid())
  phone     String   @unique // O número de telefone com DDI e sem caracteres
  profileName String? @map("profile_name") // Nome público recebido no webhook

  // Optional links to CRM entities
  leadId    String?  @unique @map("lead_id")
  clientId  String?  @unique @map("client_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  conversations WhatsappConversation[]
  labels        WhatsappContactLabel[]

  @@index([phone])
  @@map("whatsapp_contacts")
}

model WhatsappConversation {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  assigneeId String?  @map("assignee_id") // Dono (Round-Robin)

  status     String   @default("open") // open, resolved, archived
  unreadCount Int     @default(0) @map("unread_count") // para o UI
  
  // Quick lookup cache
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  lastMessageSnippet String? @db.Text @map("last_message_snippet")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  contact    WhatsappContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignee   User?           @relation("WhatsappAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  messages   WhatsappMessage[]


  @@index([contactId])
  @@index([assigneeId])
  @@index([status])
  @@map("whatsapp_conversations")
}

model WhatsappMessage {
  id             String   @id @default(uuid()) // Our internal ID
  conversationId String   @map("conversation_id")
  metaMessageId  String?  @unique @map("meta_message_id") // ID from Meta wamid.xxxx

  direction      String   // "inbound" (cliente para nois) | "outbound" (nois pro cliente)
  type           String   @default("text") // text, image, document, audio, template
  
  content        String?  @db.Text
  mediaUrl       String?  @map("media_url")
  mimeType       String?  @map("mime_type")

  status         String   @default("sent") // sent, delivered, read, failed

  timestamp      DateTime @default(now())

  createdAt      DateTime @default(now()) @map("created_at")

  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([metaMessageId])
  @@map("whatsapp_messages")
}

model WhatsappLabel {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String   @default("bg-blue-500")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  WhatsappContactLabel[]

  @@index([userId])
  @@map("whatsapp_labels")
}

model WhatsappContactLabel {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  labelId   String   @map("label_id")

  contact   WhatsappContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label     WhatsappLabel   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([contactId, labelId])
  @@index([contactId])
  @@index([labelId])
  @@map("whatsapp_contact_labels")
}


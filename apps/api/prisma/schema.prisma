// ═══════════════════════════════════════
// ProposalAI — Prisma Schema
// ═══════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══ ENUMS ═══

enum Role {
  OWNER
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum DataScope {
  OWN
  ALL
}

// ═══ MODELS ═══

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(USER)
  avatar      String?
  phone       String?
  position    String?
  active      Boolean  @default(true)
  allowedApps String[] @default([]) @map("allowed_apps") // "growth", "dev"
  allowedFunnels String[] @default([]) @map("allowed_funnels")

  // OAuth
  googleId         String? @unique @map("google_id")
  appleId          String? @unique @map("apple_id")
  twoFactorEnabled Boolean @default(true) @map("two_factor_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  sessions          Session[]
  permissions       Permission[]
  clients           Client[]
  companies         Company[]
  verificationCodes VerificationCode[]

  // Pipeline & Relacionamentos
  funnels           Funnel[]
  cadences          Cadence[]
  dealsAsConsultant Deal[]     @relation("ConsultantDeals")
  dealsAsOwner      Deal[]     @relation("AccountOwner")
  tasks             Task[]
  dealNotes         DealNote[]
  dealFiles         DealFile[]

  // SDR Automático
  sdrLeads                SdrLead[]                @relation("SdrConsultant")
  sdrMeetings             ScheduledMeeting[]       @relation("SdrMeetings")
  integrationSettings     IntegrationSetting[]
  salesCadences           SalesCadence[]
  professionals           Professional[]
  lossReasons             LossReason[]
  productCategories       ProductCategory[]
  products                Product[]
  sourceTypes             SourceType[]
  sources                 Source[]
  sourceCampaigns         SourceCampaign[]
  segments                Segment[]
  objectionCategories     ObjectionCategory[]
  objections              Objection[]
  institutionalProfile    InstitutionalProfile?
  paymentConditions       PaymentCondition[]
  checklistCategories     ChecklistCategory[]
  checklistQuestions      ChecklistQuestion[]
  securitySettings        SecuritySettings?
  notificationSettings    NotificationSettings?
  notificationPreferences NotificationPreference[]
  loginLogs               LoginLog[]
  notifications           Notification[]

  backupSettings BackupSettings?
  backupEntries  BackupEntry[]
  domainSettings DomainSettings?
  activityLogs   ActivityLog[]

  devProjects           DevProject[]
  devTasksAssigned      DevTask[]            @relation("TaskAssignee")
  devProjectMemberships DevProjectMember[]   @relation("DevProjectMembers")
  taskComments          DevTaskComment[]     @relation("TaskComments")
  taskTimeLogs          DevTaskTimeLog[]     @relation("TaskTimeLogs")
  taskBugsReported      DevTaskBug[]         @relation("TaskBugsReported")
  taskBugsAssigned      DevTaskBug[]         @relation("TaskBugsAssigned")
  taskAttachments       DevTaskAttachment[]  @relation("TaskAttachments")
  taskHistory           DevTaskHistory[]     @relation("TaskHistory")
  uploadedDocs          DevProjectDocument[] @relation("DocUploader")
  devProjectSettings    DevProjectSettings?

  featureCategories FeatureCategory[]
  leads             Lead[]            @relation("LeadOwner")
  tasksAsViewer     Task[]            @relation("TaskViewer")
  proposals         Proposal[]
  viewedProposals   Proposal[]        @relation("ProposalViewer")
  assembledProposals AssembledProposal[] @relation("ProposalAccountOwner")
  viewedAssembledProposals AssembledProposal[] @relation("AssembledProposalViewer")

  whatsappConversations WhatsappConversation[] @relation("WhatsappAssignee")
  whatsappLabels WhatsappLabel[]
  knowledgeBaseFiles KnowledgeBaseFile[]



  @@index([email])
  @@map("users")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String // 6-digit code
  type      String // login_2fa, password_reset
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([code])
  @@map("verification_codes")
}

model Permission {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  module    String // e.g. "crm.clients", "proposals", "manager.reports"
  action    String // e.g. "view", "create", "edit", "delete", "approve", "send"
  dataScope DataScope @default(OWN) @map("data_scope") // OWN = only own data, ALL = all users' data

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, action])
  @@index([userId])
  @@map("permissions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Session {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  device     String?
  browser    String?
  ip         String?
  location   String?
  lastActive DateTime @default(now()) @map("last_active")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model LoginLog {
  id     String  @id @default(uuid())
  userId String  @map("user_id")
  ip     String?
  device String?
  status String // "success", "failed"

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_logs")
}

model Company {
  id     String @id @default(uuid())
  userId String @map("user_id")

  name    String
  cnpj    String?
  segment String?
  website String?
  city    String?
  state   String?
  address String?
  notes   String? @db.Text
  status  String  @default("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients Client[]

  @@index([userId])
  @@map("companies")
}

model Client {
  id     String @id @default(uuid())
  userId String @map("user_id") // Dono do cliente / Especialista

  // Dados Básicos
  name       String
  company    String?
  companyId  String? @map("company_id")
  email      String?
  phone      String?
  role       String?
  city       String?
  state      String?
  website    String?
  segment    String?
  source     String?
  status     String  @default("prospect") // "active", "inactive", "prospect"
  isFavorite Boolean @default(false) @map("is_favorite")
  notes      String? @db.Text

  // Métricas de Vendas / CRM
  lastContact DateTime? @map("last_contact")

  totalRevenue Float @default(0) @map("total_revenue")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyRef Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals      Deal[]
  contacts   ClientContact[]
  tasks      Task[]
  proposals  Proposal[]
  assembledProposals AssembledProposal[]
  whatsappContact WhatsappContact?

  @@index([userId])
  @@index([email])
  @@index([companyId])
  @@map("clients")
}

model ClientContact {
  id        String  @id @default(uuid())
  clientId  String  @map("client_id")
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean @default(false) @map("is_primary")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@map("client_contacts")
}

// ═══════════════════════════════════════
// PIPELINE & CRM ECOSYSTEM
// ═══════════════════════════════════════

model Funnel {
  id          String  @id @default(uuid())
  userId      String  @map("user_id") // Dono/Conta
  name        String
  description String?
  isDefault   Boolean @default(false) @map("is_default")
  active      Boolean @default(true)
  orderIndex  Int     @default(0) @map("order_index")

  // ═══ Round-Robin Distribution ═══
  assigneeIds       String[] @default([]) @map("assignee_ids")
  lastAssignedIndex Int      @default(-1) @map("last_assigned_index")

  stages        FunnelStage[]
  deals         Deal[]
  salesCadences SalesCadence[]
  lossReasons   LossReason[]


  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("funnels")
}

model FunnelStage {
  id         String @id @default(uuid())
  funnelId   String @map("funnel_id")
  name       String
  color      String @default("blue")
  orderIndex Int    @default(0) @map("order_index")

  deals         Deal[]
  salesCadences SalesCadence[]
  lossReasons   LossReason[]


  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  funnel Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
  @@map("funnel_stages")
}

model Cadence {
  id            String  @id @default(uuid())
  userId        String  @map("user_id")
  name          String
  description   String?
  status        String  @default("draft") // active, paused, draft, archived
  contactsCount Int     @default(0) @map("contacts_count")
  conversions   Int     @default(0)

  // ═══ SDR Fields ═══
  tone               String  @default("formal") // formal, casual, tecnico
  targetSegment      String? @map("target_segment")
  businessHoursStart String  @default("08:00") @map("business_hours_start")
  businessHoursEnd   String  @default("18:00") @map("business_hours_end")
  timezone           String  @default("America/Sao_Paulo")
  maxAttempts        Int     @default(5) @map("max_attempts")
  automationLevel    String  @default("semi") @map("automation_level") // autopilot, semi, assisted
  playbookData       Json?   @map("playbook_data") // Snapshot do Playbook
  personaData        Json?   @map("persona_data") // Snapshot da Persona
  identityData       Json?   @map("identity_data") // Snapshot da Identity

  steps       CadenceStep[]
  enrollments LeadCadenceEnrollment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("cadences")
}

model CadenceStep {
  id         String @id @default(uuid())
  cadenceId  String @map("cadence_id")
  type       String // email, whatsapp, phone, task (legacy)
  title      String
  delay      Int    @default(0)
  delayUnit  String @default("days") // hours, days
  orderIndex Int    @default(0) @map("order_index")

  // ═══ SDR Fields ═══
  channel         String  @default("email") // email, whatsapp, phone, wait
  delayDays       Int     @default(0) @map("delay_days")
  delayHours      Int     @default(0) @map("delay_hours")
  templateContent String? @map("template_content") @db.Text
  subject         String?
  stopOnReply     Boolean @default(true) @map("stop_on_reply")

  cadence Cadence @relation(fields: [cadenceId], references: [id], onDelete: Cascade)

  @@index([cadenceId])
  @@map("cadence_steps")
}

// ═══════════════════════════════════════
// SDR AUTOMÁTICO v2.0
// ═══════════════════════════════════════

model SdrLead {
  id           String   @id @default(uuid())
  consultantId String?  @map("consultant_id")
  name         String
  email        String?
  phone        String?
  company      String?
  segment      String?
  role         String?
  tags         String[]
  notes        String?  @db.Text
  origin       String? // manual, csv_import, crm, api

  status      String @default("novo") // novo, em_cadencia, respondeu, qualificado, agendado, sem_contato, opt_out, desqualificado
  score       Int    @default(0)
  temperature String @default("frio") // quente, morno, frio

  qualificationData Json?     @map("qualification_data") // BANT extracted by AI
  optedOutAt        DateTime? @map("opted_out_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consultant User? @relation("SdrConsultant", fields: [consultantId], references: [id], onDelete: SetNull)

  enrollments       LeadCadenceEnrollment[]
  actions           CadenceAction[]
  scheduledMeetings ScheduledMeeting[]

  @@index([consultantId])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@index([temperature])
  @@map("sdr_leads")
}

model LeadCadenceEnrollment {
  id          String @id @default(uuid())
  leadId      String @map("lead_id")
  cadenceId   String @map("cadence_id")
  currentStep Int    @default(1) @map("current_step")
  status      String @default("ativo") // ativo, pausado, concluido, respondeu, agendou, opt_out

  startedAt    DateTime  @default(now()) @map("started_at")
  pausedAt     DateTime? @map("paused_at")
  completedAt  DateTime? @map("completed_at")
  nextActionAt DateTime? @map("next_action_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead    SdrLead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  cadence Cadence         @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  actions CadenceAction[]

  @@index([leadId])
  @@index([cadenceId])
  @@index([status])
  @@index([nextActionAt])
  @@map("lead_cadence_enrollments")
}

model CadenceAction {
  id           String  @id @default(uuid())
  enrollmentId String? @map("enrollment_id")
  leadId       String  @map("lead_id")

  channel    String // email, whatsapp, phone
  actionType String @map("action_type") // sent, received, opened, clicked, answered, missed, voicemail, opted_out, qualified, escalated, scheduled

  content     String? @db.Text
  aiReasoning String? @map("ai_reasoning") @db.Text
  metadata    Json? // email_id, whatsapp_message_id, call_recording_url, call_duration, transcription

  createdAt DateTime @default(now()) @map("created_at")

  enrollment LeadCadenceEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  lead       SdrLead                @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([leadId])
  @@index([actionType])
  @@index([createdAt])
  @@map("cadence_actions")
}

model QualificationCriteria {
  id          String  @id @default(uuid())
  name        String
  description String?
  fieldType   String  @default("boolean") @map("field_type") // boolean, text, number
  weight      Int     @default(0) // percentage, sum = 100
  aiPrompt    String? @map("ai_prompt") @db.Text
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([isActive])
  @@map("qualification_criteria")
}

model QualificationThresholds {
  id         String @id @default(uuid())
  hotMin     Int    @default(80) @map("hot_min")
  warmMin    Int    @default(50) @map("warm_min")
  hotAction  String @default("agendar_reuniao") @map("hot_action")
  warmAction String @default("continuar_cadencia") @map("warm_action")
  coldAction String @default("pausar_cadencia") @map("cold_action")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("qualification_thresholds")
}

model ScheduledMeeting {
  id              String   @id @default(uuid())
  leadId          String   @map("lead_id")
  consultantId    String   @map("consultant_id")
  calendarEventId String?  @map("calendar_event_id")
  meetLink        String?  @map("meet_link")
  scheduledAt     DateTime @map("scheduled_at")
  reminderSent1d  Boolean  @default(false) @map("reminder_sent_1d")
  reminderSent1h  Boolean  @default(false) @map("reminder_sent_1h")
  status          String   @default("agendada") // agendada, confirmada, cancelada, reagendada, realizada

  createdAt DateTime @default(now()) @map("created_at")

  lead       SdrLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  consultant User    @relation("SdrMeetings", fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([consultantId])
  @@index([scheduledAt])
  @@index([status])
  @@map("scheduled_meetings")
}

model Deal {
  id           String  @id @default(uuid())
  userId       String  @map("user_id") // Dono da Conta
  clientId     String  @map("client_id")
  funnelId     String  @map("funnel_id")
  stageId      String  @map("stage_id")
  consultantId String? @map("consultant_id") // Vendedor responsável

  title         String
  value         Float     @default(0)
  probability   Int       @default(0)
  status        String    @default("open") // open, won, lost
  priority      String    @default("low") // high, medium, low
  source        String    @default("Desconhecida")
  temperature   String    @default("cold") // hot, warm, cold
  expectedClose DateTime? @map("expected_close")
  nextAction    String?   @map("next_action")
  lastActivity  String?   @map("last_activity")
  tags          String[]
  assigneeIds   String[]  @default([]) @map("assignee_ids")

  notes                  DealNote[]
  files                  DealFile[]
  tasks                  Task[]
  salesCadenceExecutions SalesCadenceExecution[]
  assembledProposals     AssembledProposal[]

  // Controle de SLA (Tempo na etapa)
  stageEnteredAt DateTime @default(now()) @map("stage_entered_at")

  lossReasonId   String?     @map("loss_reason_id")
  lossReason     LossReason? @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  funnel     Funnel      @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  stage      FunnelStage @relation(fields: [stageId], references: [id])
  consultant User?       @relation("ConsultantDeals", fields: [consultantId], references: [id], onDelete: SetNull)
  user       User        @relation("AccountOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([funnelId])
  @@map("deals")
}

model SalesCadenceExecution {
  // forward declared for Deal relation — full model below
  id             String    @id @default(uuid())
  salesCadenceId String    @map("sales_cadence_id")
  dealId         String    @map("deal_id")
  currentStepIdx Int       @default(0) @map("current_step_idx")
  status         String    @default("running") // running, completed, cancelled
  nextActionAt   DateTime? @map("next_action_at")
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  salesCadence SalesCadence @relation(fields: [salesCadenceId], references: [id], onDelete: Cascade)
  deal         Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([salesCadenceId])
  @@index([dealId])
  @@index([status, nextActionAt])
  @@map("sales_cadence_executions")
}

model Task {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  clientId    String?  @map("client_id")
  dealId      String?  @map("deal_id")
  title       String
  description String?  @db.Text
  touchPoint  String?  @map("touch_point")
  date        DateTime // Due date
  status      String   @default("pending") // "pending", "completed"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewerId String? @map("viewer_id")
  viewer   User?   @relation("TaskViewer", fields: [viewerId], references: [id], onDelete: SetNull)
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal     Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@index([dealId])
  @@map("tasks")
}

model DealNote {
  id      String @id @default(uuid())
  dealId  String @map("deal_id")
  userId  String @map("user_id") // Who wrote the note
  content String @db.Text
  type    String @default("note") // "note", "email", "call", "meeting", "system_event"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([userId])
  @@map("deal_notes")
}

model DealFile {
  id           String @id @default(uuid())
  dealId       String @map("deal_id")
  userId       String @map("user_id")
  originalName String @map("original_name")
  storedName   String @map("stored_name")
  mimeType     String @map("mime_type")
  size         Int

  createdAt DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("deal_files")
}

// ═══ PROFESSIONALS & HOURLY RATES ═══

model Professional {
  id             String  @id @default(uuid())
  userId         String  @map("user_id")
  role           String
  seniority      String  @default("Pleno")
  seniorityColor String  @default("#22c55e") @map("seniority_color")
  hourlyRate     Float   @map("hourly_rate")
  currency       String  @default("BRL")
  isActive       Boolean @default(true) @map("is_active")
  history        Json    @default("[]") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("professionals")
}

// ═══ INTEGRATION SETTINGS ═══

model IntegrationSetting {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  provider    String // anthropic, sendgrid, whatsapp, synthflow, google_calendar
  isActive    Boolean   @default(false) @map("is_active")
  credentials Json      @default("{}") // Encrypted API keys / tokens
  metadata    Json      @default("{}") // Extra config (model, limits, etc.)
  lastSyncAt  DateTime? @map("last_sync_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("integration_settings")
}

// ═══════════════════════════════════════
// CRM — FLUXO DE CADÊNCIA SALES
// ═══════════════════════════════════════

model SalesCadence {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  funnelId    String  @map("funnel_id")
  stageId     String  @unique @map("stage_id") // 1 cadência por fase
  name        String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

